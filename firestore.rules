rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isMigratingRead(oldUserId) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/users/$(oldUserId)) && 
             get(/databases/$(database)/documents/users/$(oldUserId)).data.authCreated == false &&
             (get(/databases/$(database)/documents/users/$(oldUserId)).data.username + "@school.internal" == request.auth.token.email ||
              get(/databases/$(database)/documents/users/$(oldUserId)).data.email == request.auth.token.email);
    }

    function isMigratingWrite(oldUserId) {
      return isAuthenticated() && 
             getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.oldId == oldUserId;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        (request.auth.token.email == "rameshnathankaruvoolan10@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isOrganicAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'organic-admin'
      );
    }
    
    function isBreakfastAdmin() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'breakfast-admin'
      );
    }
    
    function isTeacher() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher'
      );
    }
    
    function isCoach() {
      return isAuthenticated() && (
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'coach'
      );
    }
    
    function isTeacherOrAdmin() {
      return isAdmin() || isTeacher();
    }
    
    function isCoachOrAdmin() {
      return isAdmin() || isCoach();
    }
    
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    
    function isValidUser(data) {
      return (data.uid is string || !('uid' in data)) && 
             (data.email is string || !('email' in data)) && 
             (data.fullName is string || !('fullName' in data)) && 
             (data.role in ['student', 'teacher', 'coach', 'admin', 'organic-admin', 'breakfast-admin'] || !('role' in data)) &&
             (data.points is number || !('points' in data)) &&
             (data.wellnessBadge is bool || !('wellnessBadge' in data)) &&
             (data.badgeStatus in ['none', 'pending', 'approved', 'rejected'] || !('badgeStatus' in data));
    }
    
    function isValidComment(data) {
      return data.postId is string &&
             data.authorId is string &&
             data.authorName is string &&
             data.content is string &&
             data.content.size() > 0 && data.content.size() < 1000 &&
             data.createdAt is string;
    }
    
    // ===============================================================
    // Rules
    // ===============================================================
    
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /badge_applications/{appId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /system/{docId} {
      allow read: if true;
      allow write: if isAuthenticated();
    }

    match /users/{userId} {
      allow read, list: if true;
      allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && (
        isOwner(userId) || isAdmin()
      );
      allow delete: if isAdmin() || isMigratingWrite(userId);
    }

    match /test/{docId} {
      allow read: if true;
    }

    match /home_page_data/{docId} {
      allow read, list: if true;
      allow write: if isAdmin();
    }

    match /classrooms/{classroomId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /health_records/{recordId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isTeacherOrAdmin() || isMigratingRead(resource.data.userId));
      allow create: if isTeacherOrAdmin();
      allow update: if isAdmin() || isMigratingWrite(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /activities/{activityId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isTeacherOrAdmin() || isMigratingRead(resource.data.userId));
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAuthenticated() && (isOwner(resource.data.userId) || isMigratingWrite(resource.data.userId));
      allow delete: if isAdmin();
    }

    match /modules/{moduleId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /queries/{queryId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.studentId) || isTeacherOrAdmin());
      allow create: if isAuthenticated() && isOwner(request.resource.data.studentId);
      allow update: if isTeacherOrAdmin() || (isAuthenticated() && isOwner(resource.data.studentId));
      allow delete: if isAdmin();
    }

    match /announcements/{announcementId} {
      allow read: if true;
      allow create: if isTeacherOrAdmin();
      allow update: if isTeacherOrAdmin() || (
        isAuthenticated() && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'likesCount', 'commentsCount', 'poll'])
      );
      allow delete: if isAdmin();
    }

    match /sports/{sportId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAdmin();
    }

    match /student_sports/{studentSportId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(request.resource.data.studentId);
      allow update, delete: if isCoachOrAdmin();
    }

    match /training_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isCoachOrAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isCoachOrAdmin();
    }

    match /sports_activities/{sportsActivityId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isCoachOrAdmin();
    }

    match /sports_events/{eventId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isCoachOrAdmin();
    }

    match /sports_event_participants/{participantId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isCoachOrAdmin();
    }

    match /vegetables/{vegetableId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isOrganicAdmin();
    }

    match /breakfast_items/{itemId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() || isBreakfastAdmin();
    }

    match /breakfast_reservations/{reservationId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin() || isMigratingRead(resource.data.userId));
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAdmin() || isMigratingWrite(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /breakfast_purchases/{purchaseId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin() || isBreakfastAdmin());
      allow list: if isAuthenticated() && (isAdmin() || isBreakfastAdmin() || (request.query.limit <= 100 && request.query.filters.userId == request.auth.uid));
      allow create: if isAdmin() || isBreakfastAdmin();
      allow update: if isAdmin() || isBreakfastAdmin();
      allow delete: if isAdmin();
    }

    match /organic_reservations/{reservationId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.userId) || isAdmin() || isMigratingRead(resource.data.userId));
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAdmin() || isMigratingWrite(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /badges/{badgeId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isOwner(request.resource.data.userId);
      allow update: if isAdmin() || isMigratingWrite(resource.data.userId);
      allow delete: if isAdmin();
    }

    match /likes/{likeId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.userId);
      allow update: if isAdmin() || isMigratingWrite(resource.data.userId);
      allow delete: if isAdmin() || isOwner(resource.data.userId);
    }

    match /comments/{commentId} {
      allow read: if true;
      allow create: if isAuthenticated() && isOwner(request.resource.data.authorId) && isValidComment(request.resource.data);
      allow update, delete: if isAdmin() || isOwner(resource.data.authorId);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && (
        resource.data.targetType == 'all' ||
        resource.data.targetType == 'class' ||
        (resource.data.targetType == 'user' && resource.data.targetId == request.auth.uid) ||
        isTeacherOrAdmin()
      );
      allow create: if isTeacherOrAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
