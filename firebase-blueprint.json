{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["student", "teacher", "coach", "admin", "organic-admin", "breakfast-admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "username": { "type": "string" },
        "points": { "type": "number" },
        "photoUrl": { "type": "string" },
        "class": { "type": "string" }
      },
      "required": ["uid", "email", "fullName", "role"]
    },
    "LeaderboardCache": {
      "title": "LeaderboardCache",
      "description": "Cached leaderboard data",
      "type": "object",
      "properties": {
        "users": {
          "type": "array",
          "items": { "$ref": "User" }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["users", "updatedAt"]
    },
    "HealthRecord": {
      "title": "HealthRecord",
      "description": "Student health record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "bmi": { "type": "number" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["userId", "date", "bmi", "weight", "height"]
    },
    "Activity": {
      "title": "Activity",
      "description": "Student activity record",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "name": { "type": "string" },
        "points": { "type": "number" },
        "type": { "type": "string" }
      },
      "required": ["userId", "date", "name", "points", "type"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "Class announcement",
      "type": "object",
      "properties": {
        "class": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "teacherName": { "type": "string" }
      },
      "required": ["class", "title", "content", "teacherName"]
    },
    "Module": {
      "title": "Module",
      "description": "Learning module",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "imageUrl": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "link": { "type": "string" }
      },
      "required": ["title", "imageUrl", "description", "category"]
    },
    "Comment": {
      "title": "Comment",
      "description": "User comment on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorId", "authorName", "content", "createdAt"]
    },
    "Like": {
      "title": "Like",
      "description": "User like on a post",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Breakfast item or vegetable",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "imageUrl": { "type": "string" },
        "price": { "type": "number" },
        "quantity": { "type": "number" }
      },
      "required": ["name", "imageUrl", "price"]
    },
    "BreakfastPurchase": {
      "title": "BreakfastPurchase",
      "description": "Student breakfast purchase record",
      "type": "object",
      "properties": {
        "indexNumber": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "pointsAwarded": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["indexNumber", "date", "pointsAwarded", "createdAt"]
    },
    "BreakfastSettings": {
      "title": "HealthyCanteenSettings",
      "description": "Healthy canteen settings",
      "type": "object",
      "properties": {
        "pointsPerEntry": { "type": "number" }
      },
      "required": ["pointsPerEntry"]
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "User", "description": "User profiles" },
    "/health_records/{recordId}": { "schema": "HealthRecord", "description": "Student health records" },
    "/activities/{activityId}": { "schema": "Activity", "description": "Student activities" },
    "/announcements/{announcementId}": { "schema": "Announcement", "description": "Class announcements" },
    "/modules/{moduleId}": { "schema": "Module", "description": "Learning modules" },
    "/comments/{commentId}": { "schema": "Comment", "description": "User comments" },
    "/likes/{likeId}": { "schema": "Like", "description": "User likes" },
    "/breakfast_items/{itemId}": { "schema": "Product", "description": "Breakfast items" },
    "/vegetables/{itemId}": { "schema": "Product", "description": "Vegetables" },
    "/breakfast_purchases/{purchaseId}": { "schema": "BreakfastPurchase", "description": "Breakfast purchase records" },
    "/settings/breakfast": { "schema": "BreakfastSettings", "description": "Breakfast settings" },
    "/system/leaderboard": { "schema": "LeaderboardCache", "description": "Cached leaderboard" }
  }
}
